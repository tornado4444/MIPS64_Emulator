{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Default debug build for the current platform and compiler.",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "MIPS64_DEFAULT_BUILD_TYPE": "Debug",
        "MIPS64_BUILD_CLI": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimized release build for the current platform and compiler.",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "MIPS64_DEFAULT_BUILD_TYPE": "Release",
        "MIPS64_BUILD_CLI": "ON"
      }
    },
    {
      "name": "android-debug",
      "displayName": "Android Debug",
      "description": "Android-oriented preset. Pass CMAKE_TOOLCHAIN_FILE and ANDROID_ABI from Android Studio or Gradle.",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "MIPS64_DEFAULT_BUILD_TYPE": "Debug",
        "MIPS64_BUILD_CLI": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "android-debug",
      "configurePreset": "android-debug",
      "configuration": "Debug"
    }
  ]
}
